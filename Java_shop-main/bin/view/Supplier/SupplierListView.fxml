<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import java.util.*?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox alignment="CENTER" styleClass="background" prefWidth="600.0" spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.Supplier.SupplierListController">

    <ImageView fitWidth="600.0" fitHeight="600.0" preserveRatio="true">
        <image><Image url="@/image/supplier.png"/></image>
    </ImageView>
    <Separator/>

    <Label fx:id="supplierSelectLabel" text="Select a Supplier" styleClass="heading"/>
    <Separator/>

    <ListView fx:id="supplierListView" prefWidth="600" prefHeight="600">
        <placeholder><Label text="No Suppliers listed yet"/></placeholder>
    </ListView>

    <HBox styleClass="hbox">
        <Button fx:id="shopButton" text="Shop" disable="true" prefWidth="300.0" onAction="#userShop"/>
        <Button text="Close" prefWidth="300.0" onAction="#userExit"/>
    </HBox>

    <stylesheets>
        <URL value="@/view/style.css"/>
    </stylesheets>

</VBox>
