<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.net.*?>
<?import java.util.*?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>

<VBox alignment="CENTER" styleClass="background" prefWidth="600.0" spacing="20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.Cart.CartController">

    <ImageView fitWidth="600.0" fitHeight="600.0" preserveRatio="true">
        <image><Image url="@/image/cart.png"/></image>
    </ImageView>
    <Separator/>

    <Label fx:id="productSelection" text="Ordering from...." styleClass="heading"/>
    <Separator/>

    <TableView fx:id="supplierProductsListView" prefWidth="600" prefHeight="600">
        <placeholder><Label text="No products to see here"/></placeholder>
        <columns>
            <TableColumn text="Name" prefWidth="200.0">
                <cellValueFactory>
                    <PropertyValueFactory property="name"/>
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Price" prefWidth="200.0">
                <cellValueFactory>
                    <PropertyValueFactory property="price"/>
                </cellValueFactory>
            </TableColumn>
            <TableColumn text="Stock" prefWidth="200.0">
                <cellValueFactory>
                    <PropertyValueFactory property="stock"/>
                </cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox styleClass="hbox">
        <Button fx:id="addButton" text="Add" prefWidth="150.0" onAction="#addProduct"/>
        <Button fx:id="viewButton" text="Order" prefWidth="150.0" onAction="#viewCart"/>
        <Button text="Cancel" prefWidth="150.0" onAction="#userExit"/>
        <Button fx:id="checkoutButton" text="Checkout" prefWidth="150.0" onAction="#checkoutOrder"/>
    </HBox>

    <stylesheets>
        <URL value="@/view/style.css"/>
    </stylesheets>

</VBox>
